// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Dispositivo {
  id               String                 @id @default(uuid())
  tipo             String                 // NOTEBOOK, DESKTOP, CELULAR, ACCESORIO, etc.
  marca            String?
  modelo           String?
  numeroSerie      String?
  codigoInventario String?
  estado           String?                // NUEVO, USADO, MALO, REPARACION, etc.
  detallesTecnicos String?                // JSON string for flexibility (e.g. CPU, RAM, Disk, IP, extension)
  categoria        String?                // NOTEBOOKS_CAF, PC_RECETARIO, NOTEBOOKS_MALOS, MOCHILAS, CELULARES_MALOS, etc.
  trabajadorNombre String?                // Flat worker name from Excel sheet
  trabajador       Trabajador?            @relation(fields: [trabajadorId], references: [id], onDelete: SetNull)
  trabajadorId     String?
  ubicacion        String?                // "CAF", "Recetario", "Bodega", etc.
  fechaIngreso     DateTime               @default(now())
  comentarios      String?
  reparaciones     HistorialReparacion[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

model Componente {
  id                 String   @id @default(uuid())
  nombre             String
  tipo               String   // Almacenamiento, RAM, Periférico, etc.
  cantidadDisponible Int      @default(0)
  ubicacion          String   // Bodega de destino
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Trabajador {
  id           String        @id @default(uuid())
  rut          String        @unique
  nombre       String
  cargo        String
  departamento String
  correo       String
  dispositivos Dispositivo[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model HistorialReparacion {
  id               String      @id @default(uuid())
  dispositivo      Dispositivo @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)
  dispositivoId    String
  fechaEnvio       DateTime    @default(now())
  fechaRetorno     DateTime?
  descripcionFalla String
  solucion         String?
  costo            Float?
  tecnicoEncargado String
  estado           String      // EN_PROCESO, RESUELTO, IRREPARABLE
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Cotizacion {
  id            String   @id @default(uuid())
  cantidad      Int
  numeroParte   String?
  descripcion   String
  valorUnitario Float?
  valorTotal    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Usuario {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  rol       String   @default("LECTOR") // ADMIN or LECTOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


